#!/usr/bin/expect -f

set username [lindex $argv 0]
set password [lindex $argv 1]

# Wrap the spawn in a way that we can prefix output
spawn ./client

expect "Enter your choice:"
send "1\r"

expect "Enter username:"
send "$username\r"

expect "Enter password:"
send "$password\r"

# Capture and print the status line with a username prefix
expect -re "Status:.*"
puts "\n\[$username REPORT\]: $expect_out(0,string)"

set timeout -1
vwait forever
